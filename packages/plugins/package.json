{
  "name": "@better-auth-plugins/plugins",
  "version": "0.0.1",
  "description": "Community Better Auth plugins in one package.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./botid": {
      "types": "./dist/botid/index.d.ts",
      "import": "./dist/botid/index.js"
    },
    "./arcjet": {
      "types": "./dist/arcjet/index.d.ts",
      "import": "./dist/arcjet/index.js"
    },
    "./upstash": {
      "types": "./dist/upstash/index.d.ts",
      "import": "./dist/upstash/index.js"
    },
    "./org-api-key": {
      "types": "./dist/org-api-key/index.d.ts",
      "import": "./dist/org-api-key/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@arcjet/node": ">=1",
    "better-auth": ">=1",
    "botid": ">=1.4.5"
  },
  "peerDependenciesMeta": {
    "@arcjet/node": {
      "optional": true
    },
    "botid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "better-auth": "^1.3.13",
    "botid": "^1.5.10",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
